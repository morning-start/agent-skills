{"$schema": "http://json-schema.org/draft-07/schema#", "title": "Tutorial Decision Record", "description": "教程创作过程中的结构化决策记录系统", "type": "object", "required": ["metadata", "decisions", "version_history"], "properties": {"metadata": {"type": "object", "description": "项目元数据", "required": ["project_name", "created_at", "last_updated"], "properties": {"project_name": {"type": "string", "description": "项目/书籍名称", "example": "RAG 从入门到生产实践"}, "project_version": {"type": "string", "description": "项目版本号", "example": "v1.0.0"}, "created_at": {"type": "string", "format": "date-time", "description": "首次创建时间"}, "last_updated": {"type": "string", "format": "date-time", "description": "最后更新时间"}, "total_decisions": {"type": "integer", "description": "总决策数量"}, "confirmed_decisions": {"type": "integer", "description": "已确认决策数量"}, "pending_decisions": {"type": "integer", "description": "待确认决策数量"}}}, "decisions": {"type": "object", "description": "决策记录集合，按分类组织", "patternProperties": "^(basic|content|style|project|technical)_[a-z_]+$": {"type": "object", "description": "单个决策项", "required": ["id", "category", "question", "type", "status", "value", "created_at"], "properties": {"id": {"type": "string", "description": "唯一标识符", "example": "lang_primary"}, "category": {"type": "string", "enum": ["基础配置", "内容策略", "风格偏好", "项目管理", "技术选型"], "description": "决策分类"}, "question": {"type": "string", "description": "决策问题（向用户提问时使用）", "example": "教程的主要写作语言是什么？"}, "description": {"type": "string", "description": "决策的详细说明和影响范围"}, "type": {"type": "string", "enum": ["single_choice", "multiple_choice", "text_input", "number", "boolean", "scale"], "description": "决策值类型"}, "options": {"type": "array", "description": "可选选项列表（仅 single_choice/multiple_choice 类型需要）", "items": {"type": "object", "properties": {"value": {"type": "string"}, "label": {"type": "string"}, "description": {"type": "string"}}}, "default_value": {"description": "默认值（用户未明确选择时使用）"}, "current_value": {"description": "当前值（用户确认后的值）"}, "status": {"type": "string", "enum": ["pending", "discussing", "confirmed", "changed"], "description": "决策状态"}, "priority": {"type": "string", "enum": ["critical", "high", "medium", "low"], "description": "优先级（决定讨论顺序）"}, "dependencies": {"type": "array", "description": "依赖的其他决策 ID 列表", "items": {"type": "string"}}, "impact_scope": {"type": "array", "description": "影响的章节或模块", "items": {"type": "string"}}, "reasoning": {"type": "string", "description": "做出此决策的原因/依据"}, "created_at": {"type": "string", "format": "date-time", "description": "创建时间"}, "confirmed_at": {"type": "string", "format": "date-time", "description": "确认时间"}, "confirmed_by": {"type": "string", "enum": ["user", "agent", "system"], "description": "确认方"}, "change_history": {"type": "array", "description": "变更历史记录", "items": {"type": "object", "properties": {"from_value": {}, "to_value": {}, "changed_at": {"type": "string", "format": "date-time"}, "reason": {"type": "string"}, "changed_by": {"type": "string", "enum": ["user", "agent"]}}}}}}}, "discussion_sessions": {"type": "array", "description": "讨论会话记录", "items": {"type": "object", "required": ["session_id", "started_at", "topic", "messages"], "properties": {"session_id": {"type": "string", "format": "uuid"}, "started_at": {"type": "string", "format": "date-time"}, "ended_at": {"type": "string", "format": "date-time"}, "topic": {"type": "string", "description": "本次讨论的主题"}, "triggered_by": {"type": "string", "enum": ["agent_initiated", "user_request", "conflict_detected", "missing_info"], "description": "触发原因"}, "outcome": {"type": "string", "enum": ["resolved", "deferred", "escalated", "no_change"], "description": "讨论结果"}, "affected_decisions": {"type": "array", "items": {"type": "string"}, "description": "涉及的决策 ID 列表"}, "messages": {"type": "array", "items": {"type": "object", "properties": {"role": {"type": "string", "enum": ["agent", "user"]}, "content": {"type": "string"}, "timestamp": {"type": "string", "format": "date-time"}, "decision_ref": {"type": "string"}}}}}}, "version_history": {"type": "array", "description": "决策记录文件的版本历史", "items": {"type": "object", "properties": {"version": {"type": "string"}, "timestamp": {"type": "string", "format": "date-time"}, "changes_summary": {"type": "string"}, "changed_decisions": {"type": "array", "items": {"type": "string"}}}}}}}